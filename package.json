{
  "name": "playwright-dbtetsing",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project='Mobile Chrome'",
    "test:saucedemo": "TEST_SITE=saucedemo playwright test tests/saucedemo.spec.ts --headed",
    "test:todomvc": "TEST_SITE=todomvc playwright test tests/todomvc.spec.ts --headed",
    "test:parallel": "playwright test --workers=4",
    "test:serial": "playwright test --workers=1",
    "report": "playwright show-report",
    "codegen": "playwright codegen",
    "codegen:saucedemo": "playwright codegen https://www.saucedemo.com",
    "codegen:todomvc": "playwright codegen https://demo.playwright.dev/todomvc",
    "install:browsers": "playwright install"
  },
  "keywords": [
    "playwright",
    "testing",
    "automation",
    "e2e"
  ],
  "author": "/komal",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2"
  },
  "dependencies": {
    "pg": "^8.21.0"
  }
}
